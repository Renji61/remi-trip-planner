# Copy to .env and adjust (optional for docker-compose.yml from git clone).
#
# Host port → container 8080
REMI_PORT=8080

# Registry install only (docker-compose.registry.yml) — required there:
# REMI_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/remi-trip-planner:latest

# Watchtower poll interval in seconds (default 3600 = 1 hour)
# WATCHTOWER_POLL_INTERVAL=3600

# Timezone for Watchtower logs (optional)
# TZ=UTC
