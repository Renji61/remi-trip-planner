# Copy to .env and adjust (all optional).
#
# docker-compose.yml (build from clone): host port → container 8080
REMI_PORT=8080

# docker-compose.registry.yml: defaults to ghcr.io/renji61/remi-trip-planner:latest — override only for forks/mirrors:
# REMI_IMAGE=ghcr.io/your-lowercase-github-username/remi-trip-planner:latest
# REMI_PORT=8080

# Watchtower (docker-compose.registry.yml --profile watchtower): poll interval in seconds (default 3600)
# WATCHTOWER_POLL_INTERVAL=3600

# Watchtower logs timezone (optional)
# TZ=UTC
