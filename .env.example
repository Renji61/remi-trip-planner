# Copy to .env and adjust (all optional).
#
# docker-compose.yml (build from clone): host port → container listens on 8080 inside the image
REMI_PORT=4122

# docker-compose.registry.yml: defaults to ghcr.io/renji61/remi-trip-planner:latest — override only for forks/mirrors:
# REMI_IMAGE=ghcr.io/your-lowercase-github-username/remi-trip-planner:latest
# REMI_PORT=4122
